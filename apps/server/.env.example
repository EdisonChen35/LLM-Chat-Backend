DATABASE_URL="postgresql://postgres:postgres@localhost:5432/llm_chat?schema=public"
PORT=3000

# Any OpenAI-compatible chat completions endpoint works.
# Option A — free hosted models: https://build.nvidia.com/models
LLM_API_URL="https://integrate.api.nvidia.com/v1/chat/completions"
LLM_API_KEY="nvapi-..."
LLM_MODEL="nvidia/nemotron-3-nano-omni-30b-a3b-reasoning"

# Option B — local Ollama (bonus requirement 2.1): no API key needed.
# LLM_API_URL="http://localhost:11434/v1/chat/completions"
# LLM_MODEL="llama3.2:1b"
